# Template only — copy to .env and fill in. Never commit .env.

# --- Database ---
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse_dev
POSTGRES_DB=synapse
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://synapse:synapse_dev@localhost:5432/synapse

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# --- Job Source API Keys ---
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=          # USAJobs requires your registered email here
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
SERPER_API_KEY=              # google.serper.dev — used by deep-research agents

# --- Search / Ingestion ---
SERPER_API_KEY=              # For CrewAI Deep Research / Web Search
SEARCH_KEYWORDS_PRIMARY=AI Architect
GREENHOUSE_COMPANIES=        # comma-separated board slugs, e.g. anthropic,stripe
LEVER_COMPANIES=             # comma-separated slugs
INGEST_INTERVAL_MINUTES=360
SCHEDULER_ENABLED=true

# --- Notifications (free ntfy push; leave topic empty to disable) ---
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=                  # e.g. synapse-gary-x7k2 (unguessable); subscribe at ntfy.sh/<topic>
DIGEST_HOUR=8

# --- Observability ---
PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces

# --- Auth (E6): set to require Bearer token on all API calls; empty = open (localhost) ---
AUTH_TOKEN=

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
